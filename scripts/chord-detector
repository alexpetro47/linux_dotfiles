#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["numpy"]
# ///
"""
chord-detector - Real-time note + chord detection from system audio.

Taps the monitor of the default PulseAudio/PipeWire sink (i.e. whatever is
currently playing out your speakers) via `parec`, runs a chromagram + chord
template match, and renders a live TUI.

Usage:
    chord-detector                # auto-detect default sink monitor
    chord-detector <source.name>  # tap a specific source (see: pactl list short sources)

For an i3 floating popup, see scripts/chord-detector-popup.
"""
import os
import sys
import signal
import subprocess
from collections import deque
import numpy as np

RATE = 44100
N = 8192          # analysis window (~186 ms) -> frequency resolution ~5.4 Hz
HOP = 2048        # samples read per frame (~21 fps); blocking read paces us
F_MIN, F_MAX = 55.0, 2093.0   # A1 .. C7 — fundamental range we map into chroma
SILENCE_RMS = 0.004           # below this, treat as silence

NAMES = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]

# Chord templates as pitch-class offsets from the root. Order matters only for
# display preference on near-ties (earlier = simpler/more common).
TEMPLATES = [
    ("",      (0, 4, 7)),       # major
    ("m",     (0, 3, 7)),       # minor
    ("7",     (0, 4, 7, 10)),   # dominant 7
    ("maj7",  (0, 4, 7, 11)),
    ("m7",    (0, 3, 7, 10)),
    ("dim",   (0, 3, 6)),
    ("aug",   (0, 4, 8)),
    ("sus2",  (0, 2, 7)),
    ("sus4",  (0, 5, 7)),
    ("6",     (0, 4, 7, 9)),
    ("m6",    (0, 3, 7, 9)),
    ("m7b5",  (0, 3, 6, 10)),
]

# Precompute normalized 12-d template vectors for every root.
_CHORD_VECS = []
for root in range(12):
    for label, offs in TEMPLATES:
        v = np.zeros(12)
        for o in offs:
            v[(root + o) % 12] = 1.0
        v /= np.linalg.norm(v)
        name = NAMES[root] + label
        _CHORD_VECS.append((name, len(offs), v))


FPS = RATE / HOP  # analysis frames per second (~21.5)

# Krumhansl-Kessler key profiles (for rolling key estimate).
KK_MAJ = np.array([6.35, 2.23, 3.48, 2.33, 4.38, 4.09, 2.52, 5.19, 2.39, 3.66, 2.29, 2.88])
KK_MIN = np.array([6.33, 2.68, 3.52, 5.38, 2.60, 3.53, 2.54, 4.75, 3.98, 2.69, 3.34, 3.17])


def key_from_chroma(ch):
    if ch.sum() <= 0:
        return None
    cn = ch - ch.mean()
    if np.linalg.norm(cn) <= 0:
        return None
    best = None
    for i in range(12):
        for prof, mode in ((KK_MAJ, "major"), (KK_MIN, "minor")):
            p = np.roll(prof, i)
            p = p - p.mean()
            corr = float((p @ cn) / (np.linalg.norm(p) * np.linalg.norm(cn)))
            if best is None or corr > best[0]:
                best = (corr, f"{NAMES[i]} {mode}")
    return best[1]


def estimate_bpm(flux):
    """Rough tempo from autocorrelation of the onset-flux envelope (60-200 BPM)."""
    if len(flux) < int(FPS * 3):
        return None
    f = np.asarray(flux, dtype=float)
    f = f - f.mean()
    if not np.any(f):
        return None
    ac = np.correlate(f, f, "full")[len(f) - 1:]
    lo, hi = int(FPS * 60 / 200), int(FPS * 60 / 60)
    hi = min(hi, len(ac) - 1)
    if hi <= lo:
        return None
    lag = lo + int(np.argmax(ac[lo:hi]))
    return int(round(FPS * 60 / lag)) if lag > 0 else None


def _is_music_source(name):
    # Sink monitors (laptop/computer playback) and USB-device inputs (the SP-404).
    # Deliberately excludes built-in PCI microphones, which pick up room noise.
    return name.endswith(".monitor") or "usb-" in name.lower()


def list_sources():
    """Candidate capture devices: default sink monitor + sink monitors + USB
    inputs (e.g. the SP-404), deduped. Built-in mics are excluded."""
    srcs = []
    try:
        sink = subprocess.check_output(["pactl", "get-default-sink"], text=True).strip()
        if sink:
            srcs.append(sink + ".monitor")
    except Exception:
        pass
    try:
        for line in subprocess.check_output(["pactl", "list", "short", "sources"],
                                            text=True).splitlines():
            parts = line.split("\t")
            if len(parts) >= 2 and parts[1] and _is_music_source(parts[1]):
                srcs.append(parts[1])
    except Exception:
        pass
    seen, uniq = set(), []
    for s in srcs:
        if s not in seen:
            seen.add(s)
            uniq.append(s)
    return uniq


def source_level(src, dur=0.3):
    """Mean RMS of a brief capture from src (0 if it can't be read)."""
    try:
        p = subprocess.Popen(
            ["parec", "-d", src, "--format=s16le", f"--rate={RATE}", "--channels=1", "--raw"],
            stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
        )
        data = p.stdout.read(int(RATE * dur) * 2)
        p.terminate()
    except Exception:
        return 0.0
    if not data:
        return 0.0
    a = np.frombuffer(data, dtype=np.int16).astype(np.float32) / 32768.0
    return float(np.sqrt(np.mean(a ** 2))) if a.size else 0.0


def pick_source():
    """The candidate with the most signal right now; falls back to the first
    (default sink monitor) if everything is quiet."""
    cands = list_sources()
    if not cands:
        return "@DEFAULT_MONITOR@"
    best, best_lvl = cands[0], -1.0
    for s in cands:
        lvl = source_level(s)
        if lvl > best_lvl:
            best_lvl, best = lvl, s
    return best if best_lvl > 0.002 else cands[0]


def short_name(src):
    s = src.replace("alsa_output.", "").replace("alsa_input.", "")
    if "Roland" in s or "SP-404" in s:
        return "SP-404 " + ("monitor" if s.endswith(".monitor") else "input")
    return (s[:28] + "…") if len(s) > 29 else s


# Map each FFT bin to a pitch class, once.
_freqs = np.fft.rfftfreq(N, 1.0 / RATE)
_band = (_freqs >= F_MIN) & (_freqs <= F_MAX)
_pc = np.full(_freqs.shape, -1, dtype=int)
with np.errstate(divide="ignore"):
    midi = 69.0 + 12.0 * np.log2(np.where(_freqs > 0, _freqs, 1) / 440.0)
_pc_band = (np.round(midi).astype(int) % 12)
_pc[_band] = _pc_band[_band]
_window = np.hanning(N)


def chroma(frame):
    spec = np.abs(np.fft.rfft(frame * _window))
    c = np.zeros(12)
    for pc in range(12):
        c[pc] = spec[_pc == pc].sum()
    return c


def analyze(frame):
    rms = float(np.sqrt(np.mean(frame ** 2)))
    if rms < SILENCE_RMS:
        return None, [], np.zeros(12)
    c = chroma(frame)
    if c.max() <= 0:
        return None, [], c
    cn = c / np.linalg.norm(c)
    # active notes: bins within 55% of the peak
    active = [i for i in range(12) if c[i] >= 0.55 * c.max()]
    # fewer than two distinct pitch classes -> it's a note, not a chord
    if len(active) < 2:
        return None, active, c
    # best chord by cosine similarity; nudge toward fewer notes on ties
    best, best_score = None, -1.0
    for name, size, v in _CHORD_VECS:
        s = float(cn @ v) - 0.015 * size
        if s > best_score:
            best_score, best = s, name
    return best, active, c


# ---- rendering -------------------------------------------------------------
ESC = "\033["
def col(n): return f"{ESC}38;5;{n}m"
RESET = f"{ESC}0m"
BOLD = f"{ESC}1m"
DIM = f"{ESC}2m"
CYAN, GREEN, GREY, YEL = col(45), col(82), col(240), col(220)


def bar(val, peak, width=22):
    filled = int(round((val / peak) * width)) if peak > 0 else 0
    return GREEN + "█" * filled + GREY + "░" * (width - filled) + RESET


def render(chord, active, c, source, bpm=None, keyname=None):
    peak = c.max() if c.max() > 0 else 1.0
    out = [f"{ESC}H{ESC}J"]  # home + clear
    out.append(f"  {CYAN}{BOLD}♪  REAL-TIME CHORD DETECTOR{RESET}")
    out.append(f"  {DIM}{GREY}{source[:46]}{RESET}")
    hdr = "   ".join(x for x in (f"{bpm} BPM" if bpm else "",
                                 f"key {keyname}" if keyname else "") if x)
    out.append(f"  {CYAN}{hdr}{RESET}" if hdr else "")
    if chord:
        label = chord
    elif len(active) == 1:
        label = NAMES[active[0]]      # single sustained note
    else:
        label = "—"
    notes = "  ".join(NAMES[i] for i in active) if active else f"{GREY}(silence){RESET}"
    out.append(f"     {YEL}{BOLD}{label:<12}{RESET}")
    out.append(f"     {DIM}notes:{RESET} {GREEN}{notes}{RESET}")
    out.append("")
    out.append(f"  {DIM}chroma{RESET}")
    for i in range(12):
        on = i in active
        nm = (BOLD + GREEN if on else GREY) + f"{NAMES[i]:<2}" + RESET
        out.append(f"  {nm} {bar(c[i], peak)}")
    out.append("")
    out.append(f"  {DIM}{GREY}Ctrl-C to quit{RESET}")
    sys.stdout.write("\n".join(out) + "\n")
    sys.stdout.flush()


def open_src(src):
    return subprocess.Popen(
        ["parec", "-d", src, "--format=s16le", f"--rate={RATE}",
         "--channels=1", "--raw", "--latency-msec=20"],
        stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
    )


def main():
    explicit = sys.argv[1] if len(sys.argv) > 1 else None
    source = explicit or pick_source()       # loudest of monitor / SP-404 input / etc.
    state = {"proc": open_src(source)}

    def cleanup(*_):
        try:
            state["proc"].terminate()
        except Exception:
            pass
        sys.stdout.write(f"{ESC}?25h{RESET}\n")  # show cursor
        sys.stdout.flush()
        os._exit(0)

    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)

    buf = np.zeros(N, dtype=np.float32)
    nbytes = HOP * 2
    ema = np.zeros(12)                       # smoothed chroma -> rolling key
    flux = deque(maxlen=int(FPS * 8))        # onset-strength history -> rolling BPM
    prev_energy = None
    bpm = keyname = None
    fc = 0
    silent = 0
    rescan_after = int(FPS * 5)              # ~5s quiet -> follow audio to a livelier source
    sys.stdout.write(f"{ESC}?25l{ESC}2J")  # hide cursor, clear
    try:
        while True:
            raw = state["proc"].stdout.read(nbytes)
            if not raw or len(raw) < nbytes:
                break
            new = np.frombuffer(raw, dtype=np.int16).astype(np.float32) / 32768.0
            buf = np.roll(buf, -HOP)
            buf[-HOP:] = new
            chord, active, c = analyze(buf)

            energy = float(c.sum())
            if prev_energy is not None:
                flux.append(max(0.0, energy - prev_energy))
            prev_energy = energy
            if energy > 0 and active:        # only fold tonal frames into the key estimate
                ema = 0.96 * ema + 0.04 * c
            fc += 1
            if fc % int(FPS) == 0:           # refresh ~once per second
                bpm = estimate_bpm(flux) or bpm
                keyname = key_from_chroma(ema) or keyname

            # auto-follow: after sustained silence, re-pick the source with signal
            silent = silent + 1 if not active else 0
            if explicit is None and silent >= rescan_after:
                cand = pick_source()
                if cand != source and source_level(cand) > 0.002:
                    try:
                        state["proc"].terminate()
                    except Exception:
                        pass
                    source = cand
                    state["proc"] = open_src(source)
                    buf[:] = 0
                    flux.clear()
                    ema[:] = 0.0
                    bpm = keyname = None
                silent = 0

            label = short_name(source) + ("" if explicit else "  (auto)")
            render(chord, active, c, label, bpm, keyname)
    finally:
        cleanup()


if __name__ == "__main__":
    main()
