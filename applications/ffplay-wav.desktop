[Desktop Entry]
Type=Application
Name=Play audio (ffplay)
Comment=Play an audio file with ffplay — no window, auto-exits at end
Exec=ffplay -nodisp -autoexit -loglevel quiet %f
Terminal=false
NoDisplay=true
MimeType=audio/vnd.wave;audio/x-wav;audio/wav;audio/x-aiff;audio/x-aifc;audio/flac;audio/mpeg;audio/ogg;audio/mp4;audio/aac;audio/x-ms-wma;audio/x-wavpack;
