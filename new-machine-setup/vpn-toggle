#!/bin/bash
# vpn-toggle - Toggle Tailscale exit node (DigitalOcean droplet)
# Server is never modified; this only changes the laptop-side route.

EXIT_NODE_IP="100.101.204.6"

if tailscale status 2>/dev/null | grep -q '; exit node;'; then
    # Currently routing through droplet - turn off
    if ! out=$(tailscale set --exit-node= 2>&1); then
        notify-send -u critical "VPN" "Failed to disable: $out"
        exit 1
    fi
    notify-send -u low "VPN" "Off - exposed on local IP"
    polybar-msg action vpn hook 1 2>/dev/null
else
    # Not routing - turn on
    if ! out=$(tailscale set --exit-node="$EXIT_NODE_IP" --exit-node-allow-lan-access=true 2>&1); then
        notify-send -u critical "VPN" "Failed to enable: $out"
        exit 1
    fi
    notify-send -u low "VPN" "On - routing through droplet"
    polybar-msg action vpn hook 0 2>/dev/null
fi
