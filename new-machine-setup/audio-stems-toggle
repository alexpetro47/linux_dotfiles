#!/bin/bash
# audio-stems-toggle - Toggle system-audio recording; on stop, split into stems and prep for sampling.
# Press once (Alt+Shift+s) to start capturing whatever is playing, press again to stop. Then:
#   - Demucs (htdemucs_ft) separates into vocals / drums / bass / other
#   - detects BPM + key (folder named <datetime>_<bpm>bpm_<key>_stems, plus a <bpm>bpm_<key> marker file)
#   - converts the full mix (00_full) and each stem to SP-404-ready 48k/16-bit, peak-normalized to -1 dBFS, numbered in chop order
#   - also writes 05_no_drums (full mix with the drums stem removed)
#   - chops the drums stem into one-shots in drums_oneshots/
# Output: ~/Downloads/<datetime>_<bpm>bpm_<key>_stems/
#
# Concurrency: separation runs in its own process, so you can stop one recording and immediately
# start the next while the previous still separates. One recording at a time; any number of
# separations in flight. The polybar icon shows recording (red note) if a capture is active,
# else separating (yellow hourglass) if any job is still running, else idle.

STATEDIR="/tmp/audio-stems"
JOBSDIR="$STATEDIR/jobs"             # one marker file per in-flight separation (named by its pid)
RECPID="$STATEDIR/rec.pid"           # ffmpeg pid of the in-progress recording (one at a time)
RECWAV="$STATEDIR/rec.path"          # wav path of the in-progress recording
MODEL="htdemucs_ft"                  # fine-tuned 4-stem model (vocals/drums/bass/other)
mkdir -p "$JOBSDIR"

_notify() { dunstify -a "stems" -t 4000 -r "$1" -u low "$2" "$3"; }

_recording() { [[ -f "$RECPID" ]] && kill -0 "$(cat "$RECPID" 2>/dev/null)" 2>/dev/null; }

# Is any separation still running? Prunes markers whose process has died.
_jobs_active() {
    local f
    for f in "$JOBSDIR"/*; do
        [[ -e "$f" ]] || continue
        kill -0 "$(basename "$f")" 2>/dev/null && return 0
        rm -f "$f"
    done
    return 1
}

# Repaint the polybar icon from current global state: recording > separating > idle.
_refresh() {
    local hook=0
    if _recording; then hook=1
    elif _jobs_active; then hook=2; fi
    polybar-msg action stems hook "$hook" 2>/dev/null || true
}

if _recording; then
    # ---- STOP this recording, then separate it (other jobs keep running) ----
    pid=$(cat "$RECPID"); rm -f "$RECPID"
    wav=$(cat "$RECWAV" 2>/dev/null); rm -f "$RECWAV"
    kill -INT "$pid"
    # wait for ffmpeg to flush and close the file (cap at ~5s)
    for _ in $(seq 1 25); do kill -0 "$pid" 2>/dev/null || break; sleep 0.2; done

    if [[ ! -s "$wav" ]]; then
        _notify 88888 "Stems" "Recording was empty — aborted"
        _refresh
        exit 1
    fi

    stamp=$(basename "${wav%.*}" | sed 's/^audio-stems-//')
    job="$JOBSDIR/$$"; touch "$job"          # mark this separation in flight
    trap 'rm -f "$job"; _refresh' EXIT       # always clear our marker + repaint on the way out
    nid=$$                                    # per-job notification id (so jobs don't clobber each other)

    _notify "$nid" "Stems" "Separating + analyzing $stamp…"
    _refresh

    # separate: vocals / drums / bass / other (16-bit WAV; --filename flattens the per-track subfolder)
    tmpout=$(mktemp -d)
    if ! demucs -n "$MODEL" --filename "{stem}.{ext}" -o "$tmpout" "$wav" &>"/tmp/audio-stems-demucs-$stamp.log"; then
        _notify "$nid" "Stems" "Demucs failed — see /tmp/audio-stems-demucs-$stamp.log"
        rm -rf "$tmpout"
        exit 1
    fi

    # analyze the source recording once for tempo + key (graceful fallback if it fails)
    read -r bpm key _ < <(audio-analyze tempo-key "$wav" 2>"/tmp/audio-stems-analyze-$stamp.log") || true
    [[ -n "$bpm" ]] || bpm="NA"
    [[ -n "$key" ]] || key="NA"

    # folder: ~/Downloads/<datetime>_<bpm>bpm_<key>_stems
    dest="$HOME/Downloads/${stamp}_${bpm}bpm_${key}_stems"
    mkdir -p "$dest"

    # SP-404-ready: 48k/16-bit stereo, peak-normalized to -1 dBFS, numbered in chop/use order.
    # 00 is the full untouched mix; the rest are the isolated stems in the order you reach for
    # them when chopping: vocals (hook) first, then melody, bass, drums.
    sox "$wav" -b 16 "$dest/00_full.wav" rate 48000 norm -1 2>/dev/null || cp "$wav" "$dest/00_full.wav"
    i=0
    for stem in vocals other bass drums; do
        i=$((i + 1))
        src="$tmpout/$MODEL/$stem.wav"
        [[ -f "$src" ]] || continue
        out="$dest/$(printf '%02d' "$i")_${stem}.wav"
        sox "$src" -b 16 "$out" rate 48000 norm -1 2>/dev/null || cp "$src" "$out"
    done

    # full mix with drums removed = vocals + other + bass summed (same SP-404 treatment)
    nd=("$tmpout/$MODEL/vocals.wav" "$tmpout/$MODEL/other.wav" "$tmpout/$MODEL/bass.wav")
    if [[ -f "${nd[0]}" && -f "${nd[1]}" && -f "${nd[2]}" ]]; then
        sox -m "${nd[@]}" -b 16 "$dest/05_no_drums.wav" rate 48000 norm -1 2>/dev/null || true
    fi
    rm -rf "$tmpout"

    # chop the (normalized) drums stem into one-shots, alongside the full 04_drums.wav
    drums="$dest/04_drums.wav"
    [[ -f "$drums" ]] && audio-analyze slice "$drums" "$dest/drums_oneshots" &>"/tmp/audio-stems-slice-$stamp.log" || true

    # quick-glance marker: an empty file whose name encodes tempo + key
    touch "$dest/${bpm}bpm_${key}"

    _notify "$nid" "Stems Ready" "$dest  •  ${bpm} BPM  ${key}"
    thunar "$dest" &>/dev/null &
    # EXIT trap removes the job marker and repaints the indicator
else
    # ---- START: capture the default sink's monitor (system audio) ----
    monitor="$(pactl get-default-sink).monitor"
    wav="/tmp/audio-stems-$(date +%Y-%m-%d_%H-%M-%S).wav"
    stamp=$(basename "${wav%.*}" | sed 's/^audio-stems-//')
    echo "$wav" > "$RECWAV"
    # downmix to stereo 44.1k — what Demucs expects
    ffmpeg -y -f pulse -i "$monitor" -ac 2 -ar 44100 "$wav" &>"/tmp/audio-stems-ffmpeg-$stamp.log" &
    echo $! > "$RECPID"
    _refresh
    _notify 88888 "Recording" "System audio → $(basename "$wav")"
fi
