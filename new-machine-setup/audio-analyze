#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10,<3.13"
# dependencies = ["librosa", "soundfile", "numpy"]
# ///
"""Tiny audio analysis helper for the stem pipeline.

  audio-analyze tempo-key <file>     -> prints "<bpm> <key> <camelot>"  e.g. "174 Amin 8A"
  audio-analyze slice <file> <outdir> -> writes onset-sliced one-shots, prints slice count
"""
import os
import sys

import numpy as np
import librosa
import soundfile as sf

NOTES = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]
# Krumhansl-Kessler key profiles
MAJ = np.array([6.35, 2.23, 3.48, 2.33, 4.38, 4.09, 2.52, 5.19, 2.39, 3.66, 2.29, 2.88])
MIN = np.array([6.33, 2.68, 3.52, 5.38, 2.60, 3.53, 2.54, 4.75, 3.98, 2.69, 3.34, 3.17])
CAMELOT = {
    "Cmaj": "8B", "C#maj": "3B", "Dmaj": "10B", "D#maj": "5B", "Emaj": "12B",
    "Fmaj": "7B", "F#maj": "2B", "Gmaj": "9B", "G#maj": "4B", "Amaj": "11B",
    "A#maj": "6B", "Bmaj": "1B",
    "Amin": "8A", "A#min": "3A", "Bmin": "10A", "Cmin": "5A", "C#min": "12A",
    "Dmin": "7A", "D#min": "2A", "Emin": "9A", "Fmin": "4A", "F#min": "11A",
    "Gmin": "6A", "G#min": "1A",
}


def detect_bpm(y, sr):
    onset_env = librosa.onset.onset_strength(y=y, sr=sr)
    tempo = librosa.feature.tempo(onset_envelope=onset_env, sr=sr)
    return int(round(float(np.atleast_1d(tempo)[0])))


def detect_key(y, sr):
    chroma = librosa.feature.chroma_cqt(y=y, sr=sr).mean(axis=1)
    best = None
    for i in range(12):
        for prof, mode in ((MAJ, "maj"), (MIN, "min")):
            corr = np.corrcoef(np.roll(prof, i), chroma)[0, 1]
            if best is None or corr > best[0]:
                best = (corr, NOTES[i] + mode)
    return best[1]


def apply_fades(seg, sr, ms=3):
    n = min(int(sr * ms / 1000), seg.shape[-1] // 2)
    if n <= 0:
        return seg
    ramp = np.linspace(0.0, 1.0, n, dtype=seg.dtype)
    seg = seg.copy()
    seg[..., :n] *= ramp
    seg[..., -n:] *= ramp[::-1]
    return seg


def slice_oneshots(infile, outdir):
    y, sr = librosa.load(infile, sr=None, mono=False)
    mono = librosa.to_mono(y) if y.ndim > 1 else y
    onsets = librosa.onset.onset_detect(y=mono, sr=sr, backtrack=True, units="samples")
    bounds = list(onsets) + [y.shape[-1]]
    os.makedirs(outdir, exist_ok=True)
    count = 0
    for s, e in zip(bounds, bounds[1:]):
        if e - s < int(0.03 * sr):  # skip sub-30ms fragments
            continue
        seg = apply_fades(y[..., s:e] if y.ndim > 1 else y[s:e], sr)
        data = seg.T if seg.ndim > 1 else seg
        count += 1
        sf.write(os.path.join(outdir, f"hit_{count:03d}.wav"), data, sr, subtype="PCM_16")
    return count


def main():
    cmd = sys.argv[1]
    if cmd == "tempo-key":
        y, sr = librosa.load(sys.argv[2], sr=22050, mono=True)
        key = detect_key(y, sr)
        print(f"{detect_bpm(y, sr)} {key} {CAMELOT.get(key, '?')}")
    elif cmd == "slice":
        print(slice_oneshots(sys.argv[2], sys.argv[3]))
    else:
        sys.exit(f"unknown command: {cmd}")


if __name__ == "__main__":
    main()
