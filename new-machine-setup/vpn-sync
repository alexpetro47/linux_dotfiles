#!/bin/bash
# vpn-sync - Sync polybar icon with actual Tailscale exit node state
# Called on startup so icon reflects reality.

if tailscale status 2>/dev/null | grep -q '; exit node;'; then
    # VPN on (default) - no icon
    polybar-msg action vpn hook 0 2>/dev/null
else
    # VPN off - warning icon
    polybar-msg action vpn hook 1 2>/dev/null
fi
